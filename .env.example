# ---- AWS Bedrock (Vision-Language Model: Claude 3.5 Sonnet) ----
# Bedrock auth uses the standard AWS credential chain (SigV4), NOT a bearer key.
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="AKIA-replace-me"
AWS_SECRET_ACCESS_KEY="replace-me"
# Optional: only needed for temporary/STS credentials.
# AWS_SESSION_TOKEN=""
# Override the default Bedrock model id if desired.
BEDROCK_MODEL_ID="us.anthropic.claude-sonnet-4-5-20250929-v1:0"

# ---- S3 (direct image upload; bypasses the inline-image size limit) ----
# Bucket should be in the same region as AWS_REGION above.
S3_BUCKET="safespace-scans"
S3_PREFIX="scans"
# Your AWS account id (used as the Bedrock s3Location bucketOwner).
AWS_ACCOUNT_ID="073158194660"

# ---- Butterbase (REST) ----
# Plug in your Butterbase REST credentials here. The DB service reads these.
BUTTERBASE_API_URL="https://api.butterbase.dev/v1"
BUTTERBASE_API_KEY="bb-replace-me"
BUTTERBASE_TABLE="scans"
